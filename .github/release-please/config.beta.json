{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/v17.6.0/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": false,
  "bump-minor-pre-major": true,
  "versioning": "prerelease",
  "prerelease": true,
  "prerelease-type": "beta",
  "draft": true,
  "force-tag-creation": true,
  "always-update": true,
  "label": "autorelease: pending-beta",
  "release-label": "autorelease: tagged-beta",
  "pull-request-title-pattern": "chore: release ${version}",
  "packages": {
    ".": {
      "package-name": "dayjot-desktop",
      "component": "dayjot-desktop-beta",
      "changelog-path": "apps/desktop/CHANGELOG.beta.md",
      "exclude-paths": ["docs", "fixtures", ".github", "apps/extension"],
      "extra-files": [
        {
          "type": "json",
          "path": "apps/desktop/package.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
