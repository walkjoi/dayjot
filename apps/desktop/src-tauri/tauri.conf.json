{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "reflect-open",
  "version": "0.1.0",
  "identifier": "com.alex.reflect-open",
  "build": {
    "beforeDevCommand": "pnpm sidecar && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm sidecar && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "reflect-open",
        "width": 1300,
        "height": 650,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "iOS": {
      "developmentTeam": "789ULN5MZB",
      "template": "src-tauri/ios.project.yml"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}