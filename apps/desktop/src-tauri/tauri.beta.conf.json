{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DayJot Beta",
  "identifier": "app.dayjot.desktop.beta",
  "app": {
    "windows": [
      {
        "title": "DayJot Beta",
        "width": 1300,
        "height": 650,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false,
        "visible": false
      }
    ]
  },
  "bundle": {
    "icon": [
      "icons-beta/32x32.png",
      "icons-beta/128x128.png",
      "icons-beta/128x128@2x.png",
      "icons-beta/icon.icns",
      "icons-beta/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/walkjoi/dayjot/releases/download/updater-beta/latest.json"
      ]
    }
  }
}
